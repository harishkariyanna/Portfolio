# MongoDB Connection (Atlas M0 Free Tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Authentication Secret (Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-secret-key-here-minimum-32-characters

# Groq API Key (for AI chatbot and resume generation)
GROQ_API_KEY=gsk_your-groq-api-key-here

# OpenAI API Key (legacy - optional)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Cloudinary Configuration (for media uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS configuration)
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Frontend Environment Variable (set in Vercel dashboard)
# VITE_API_URL=https://your-app.onrender.com

# Email Configuration (for OTP emails - optional, will log to console if not set)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@portfolio.com

# Admin Credentials (for seeding - optional, defaults: admin@portfolio.com / Admin@123456)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin@123456
